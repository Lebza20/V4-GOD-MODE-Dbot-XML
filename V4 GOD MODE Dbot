<?xml version="1.0" encoding="UTF-8"?>
<xml xmlns="http://www.w3.org/1999/xhtml">
  <!-- V4 GOD MODE Dbot - Capped Martingale with 60s cooldown after 3 losses -->
  <variables>
    <variable id="target_digit">target_digit</variable>
    <variable id="base_stake">base_stake</variable>
    <variable id="stake">stake</variable>
    <variable id="loss_streak">loss_streak</variable>
  </variables>

  <!-- Initialisation (runs once on start) -->
  <block type="procedures_defnoreturn" id="init" x="20" y="20">
    <field name="NAME">on start</field>
    <statement name="STACK">
      <block type="variables_set" id="set_base_stake">
        <field name="VAR" id="base_stake">base_stake</field>
        <value name="VALUE">
          <block type="math_number" id="base_stake_value">
            <field name="NUM">1</field>
          </block>
        </value>
        <next>
          <block type="variables_set" id="set_stake">
            <field name="VAR" id="stake">stake</field>
            <value name="VALUE">
              <block type="variables_get" id="get_base_stake">
                <field name="VAR" id="base_stake">base_stake</field>
              </block>
            </value>
            <next>
              <block type="variables_set" id="set_loss_streak">
                <field name="VAR" id="loss_streak">loss_streak</field>
                <value name="VALUE">
                  <block type="math_number" id="loss_streak_init">
                    <field name="NUM">0</field>
                  </block>
                </value>
              </block>
            </next>
          </block>
        </next>
      </block>
    </statement>
  </block>

  <!-- Main trading loop – runs after each contract -->
  <block type="controls_once_per_contract" id="main_loop" x="20" y="200">
    <statement name="DO">
      <!-- Place a new trade (DIGITDIFF on R_100, 1 tick duration) -->
      <block type="purchase" id="purchase_trade">
        <field name="CONTRACT_TYPE">DIGITDIFF</field>
        <field name="SYMBOL">R_100</field>
        <value name="DURATION">
          <block type="math_number" id="duration">
            <field name="NUM">1</field>
          </block>
        </value>
        <value name="AMOUNT">
          <block type="variables_get" id="get_stake_for_trade">
            <field name="VAR" id="stake">stake</field>
          </block>
        </value>
        <value name="PREDICTION">
          <block type="variables_get" id="get_target_digit">
            <field name="VAR" id="target_digit">target_digit</field>
          </block>
        </value>
        <next>
          <!-- Handle trade result -->
          <block type="controls_if" id="result_handler">
            <value name="IF0">
              <block type="check_result" id="check_loss">
                <field name="RESULT">loss</field>
              </block>
            </value>
            <statement name="DO0">
              <!-- LOSS HANDLER -->
              <block type="variables_set" id="inc_loss_streak">
                <field name="VAR" id="loss_streak">loss_streak</field>
                <value name="VALUE">
                  <block type="math_arithmetic" id="add_one">
                    <field name="OP">ADD</field>
                    <value name="A">
                      <block type="variables_get" id="get_loss_streak">
                        <field name="VAR" id="loss_streak">loss_streak</field>
                      </block>
                    </value>
                    <value name="B">
                      <block type="math_number" id="one">
                        <field name="NUM">1</field>
                      </block>
                    </value>
                  </block>
                </value>
                <next>
                  <!-- SMART RECOVERY (CAPPED) -->
                  <block type="controls_if" id="smart_recovery">
                    <value name="IF0">
                      <block type="logic_compare" id="streak_lt_3">
                        <field name="OP">LT</field>
                        <value name="A">
                          <block type="variables_get" id="get_loss_streak2">
                            <field name="VAR" id="loss_streak">loss_streak</field>
                          </block>
                        </value>
                        <value name="B">
                          <block type="math_number" id="three">
                            <field name="NUM">3</field>
                          </block>
                        </value>
                      </block>
                    </value>
                    <statement name="DO0">
                      <!-- Double stake if streak < 3 -->
                      <block type="variables_set" id="double_stake">
                        <field name="VAR" id="stake">stake</field>
                        <value name="VALUE">
                          <block type="math_arithmetic" id="multiply_by_2">
                            <field name="OP">MULTIPLY</field>
                            <value name="A">
                              <block type="variables_get" id="get_stake2">
                                <field name="VAR" id="stake">stake</field>
                              </block>
                            </value>
                            <value name="B">
                              <block type="math_number" id="two">
                                <field name="NUM">2</field>
                              </block>
                            </value>
                          </block>
                        </value>
                      </block>
                    </statement>
                    <statement name="ELSE">
                      <!-- AUTO PAUSE AFTER 3 LOSSES (or more) -->
                      <block type="controls_wait" id="pause_60s">
                        <value name="SECONDS">
                          <block type="math_number" id="sixty">
                            <field name="NUM">60</field>
                          </block>
                        </value>
                        <next>
                          <block type="variables_set" id="reset_stake_after_pause">
                            <field name="VAR" id="stake">stake</field>
                            <value name="VALUE">
                              <block type="variables_get" id="get_base_stake_after_pause">
                                <field name="VAR" id="base_stake">base_stake</field>
                              </block>
                            </value>
                          </block>
                        </next>
                      </block>
                    </statement>
                  </block>
                </next>
              </block>
            </statement>
            <statement name="ELSE">
              <!-- WIN HANDLER -->
              <block type="variables_set" id="reset_loss_streak">
                <field name="VAR" id="loss_streak">loss_streak</field>
                <value name="VALUE">
                  <block type="math_number" id="zero">
                    <field name="NUM">0</field>
                  </block>
                </value>
                <next>
                  <block type="variables_set" id="reset_stake_win">
                    <field name="VAR" id="stake">stake</field>
                    <value name="VALUE">
                      <block type="variables_get" id="get_base_stake_win">
                        <field name="VAR" id="base_stake">base_stake</field>
                      </block>
                    </value>
                  </block>
                </next>
              </block>
            </statement>
          </block>
        </next>
      </block>
    </statement>
  </block>
</xml>
